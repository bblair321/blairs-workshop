# Database (Neon, Supabase, or local Postgres)
DATABASE_URL="postgresql://user:password@localhost:5432/modhost?schema=public"

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-secret"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin panel password (separate from user accounts)
ADMIN_PASSWORD="change-me-admin-password"

# Optional: salt for download IP hashing
IP_HASH_SALT="random-salt"

# Cloudflare R2 (S3-compatible object storage)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="mods"

# Stripe (Phase 2 — paid mods)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
