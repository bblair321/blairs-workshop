# Database
# Local Postgres example:
# DATABASE_URL="postgresql://postgres@localhost:5432/modhost?schema=public"
#
# Neon — pooled URL for the app; unpooled for Prisma CLI (migrate, db push)
# DATABASE_URL="postgresql://...@ep-xxx-pooler....neon.tech/neondb?sslmode=require&connect_timeout=15"
# DATABASE_URL_UNPOOLED="postgresql://...@ep-xxx....neon.tech/neondb?sslmode=require"
DATABASE_URL="postgresql://user:password@localhost:5432/modhost?schema=public"

# NextAuth — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET="change-me-to-a-random-secret"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin panel password (separate from user accounts)
ADMIN_PASSWORD="change-me-admin-password"

# Public contact email (footer + terms)
CONTACT_EMAIL="bblair321@yahoo.com"

# Optional: salt for download IP hashing
IP_HASH_SALT="generate-a-random-secret"

# Cloudflare R2 (S3-compatible object storage)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="mods"

# Stripe (Phase 2 — paid mods)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Google Search Console — the code from the "HTML tag" verification method
# (just the content value, not the whole meta tag)
GOOGLE_SITE_VERIFICATION=""
